{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "mutate": [
    "src/domain/balances.ts",
    "src/domain/simplify.ts"
  ],
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "concurrency": 4,
  "coverageAnalysis": "perTest",
  "timeoutMS": 60000
}
