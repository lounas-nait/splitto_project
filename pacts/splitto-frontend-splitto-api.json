{
  "consumer": {
    "name": "splitto-frontend"
  },
  "interactions": [
    {
      "description": "une requête pour les balances du groupe group-1",
      "providerStates": [
        {
          "name": "group-1 a 3 membres et 2 dépenses"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/groups/group-1/balances"
      },
      "response": {
        "body": {
          "balances": {
            "alice": 20,
            "bob": -10,
            "charlie": -10
          },
          "groupId": "group-1",
          "settlements": [
            {
              "amount": 10,
              "from": "bob",
              "to": "alice"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.balances": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.groupId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.settlements": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.settlements[*].amount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.settlements[*].from": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.settlements[*].to": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {},
          "status": {}
        },
        "status": 200
      }
    },
    {
      "description": "une requête pour un groupe inexistant",
      "providerStates": [
        {
          "name": "aucun groupe inexistant"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/groups/inexistant/balances"
      },
      "response": {
        "body": {
          "error": "Group not found"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          },
          "header": {},
          "status": {}
        },
        "status": 404
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "13.2.0"
    },
    "pactRust": {
      "ffi": "0.4.22",
      "models": "1.2.3"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "splitto-api"
  }
}